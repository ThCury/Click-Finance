classDiagram
direction LR

class User {
  +int id
  +string username
  +string email
  +string hashed_password
  +bool is_admin
  +bool is_verified
  +string? bio
  +datetime created_at
}

class Wallet {
  +int id
  +string name
  +string? description
  +bool is_public
  +int user_id
  +datetime created_at
}

class WalletSnapshot {
  +int id
  +int wallet_id
  +datetime snapshot_date
  +float total_value
  +float total_cost
  +float profitability
}

class Asset {
  +int id
  +string ticker
  +string name
  +string type
  +float current_price
  +datetime last_update
}

class Transaction {
  +int id
  +int asset_id
  +int wallet_id
  +datetime date
  +string type
  +float quantity
  +float price
  +float costs
}

class Post {
  <<abstract>>
  +int id
  +int user_id
  +string title
  +string content
  +bool is_public
  +datetime created_at
  +datetime updated_at
}

class SocialPost {
  +string category
}

class InformationPost {
  +string info_type
  +string source
}

class AssetInformation {
  +int asset_id
}

class GeneralInformation {
  +string theme
}

class Comment {
  +int id
  +int user_id
  +int post_id
  +string content
  +datetime created_at
  +datetime updated_at
}

class Like {
  +int id
  +int user_id
  +int post_id
  +datetime created_at
}

class SavedPost {
  +int id
  +int user_id
  +int post_id
  +datetime created_at
}

class Follow {
  +int id
  +int follower_id
  +int followed_id
  +datetime created_at
}

class VerificationRequest {
  +int id
  +int user_id
  +string document_type
  +string document_number
  +string status
  +datetime requested_at
  +datetime reviewed_at
}

class PostAsset {
  +int id
  +int post_id
  +int asset_id
}

class PostWallet {
  +int id
  +int post_id
  +int wallet_id
}

Post <|-- SocialPost
Post <|-- InformationPost
InformationPost <|-- AssetInformation
InformationPost <|-- GeneralInformation

User "1" --> "0..*" Wallet : owns
User "1" --> "0..*" Post : publishes
User "1" --> "0..*" Comment : writes
User "1" --> "0..*" Like : likes
User "1" --> "0..*" SavedPost : saves
User "1" --> "0..*" VerificationRequest : requests
User "1" --> "0..*" Follow : follower
User "1" --> "0..*" Follow : followed

Wallet "1" --> "0..*" Transaction : contains
Wallet "1" --> "0..*" WalletSnapshot : history
Wallet --> User : owner

Transaction --> Wallet : wallet
Transaction --> Asset : asset
Asset "1" --> "0..*" Transaction : referenced_in

Post "1" --> "0..*" Comment : has
Post "1" --> "0..*" Like : receives
Post "1" --> "0..*" SavedPost : saved_by
Post "1" --> "0..*" PostAsset : mentions
Post "1" --> "0..*" PostWallet : mentions

Comment --> User : user
Comment --> Post : post

Like --> User : user
Like --> Post : post

SavedPost --> User : user
SavedPost --> Post : post

Follow --> User : follower
Follow --> User : followed

VerificationRequest --> User : user

PostAsset --> Post : post
PostAsset --> Asset : asset

PostWallet --> Post : post
PostWallet --> Wallet : wallet

AssetInformation --> Asset : related_asset
WalletSnapshot --> Wallet : wallet
